@using System.Globalization;
<MudCard>
    <MudCardHeader>
        <CardHeaderContent>
            <MudText>Compteur:@Serial</MudText>

        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (Sold)
        {
            <MudGrid>
                <MudItem xs="6">
                    <MudText Align="Align.Center" Typo="Typo.subtitle2">HABITAT DU GOLF</MudText>
                    <MudText Align="Align.Center">(+228) 91378364</MudText>
                    <MudText Align="Align.Center">Lomé-Togo</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Align="Align.End">@DateTime.Today.ToShortDateString()</MudText>
                </MudItem>
            </MudGrid>
            <MudText Align="Align.Center">Reçu N°: @Ref</MudText>
            <MudText>Code: @Code</MudText>
            <MudText>KW:@Kw</MudText>
        }
        <MudGrid>
            <MudItem xs="12">
                <MudSimpleTable Striped="true" Dense="true" Bordered="true">
                    <thead>
                        <tr>
                            <th>Libellé</th>
                            <th>Prix</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Achat de Crédit</td>
                            <td><MoneyField Disabled="true" Variant="Variant.Text">@Amount.ToString("N0", new CultureInfo("fr-FR"))</MoneyField></td>
                        </tr>
                        <tr>
                            <td>Frais</td>
                            <td> <MoneyField Variant="Variant.Text">@getFees().ToString("N0", new CultureInfo("fr-FR"))</MoneyField></td>
                        </tr>
                        <tr>
                            <td>Total</td>
                            <td><MoneyField Variant="Variant.Text">@Total.ToString("N0", new CultureInfo("fr-FR"))</MoneyField></td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
        </MudGrid>

    </MudCardContent>
</MudCard>
