@inject Microsoft.Extensions.Localization.IStringLocalizer<NavMenu> _localizer
@using System.Security.Claims

<UserCard />
<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Home">@_localizer["Home"]</MudNavLink>

    @* ── TABLEAU DE BORD ── *@
    @if (_canViewDashboards)
    {
        <MudDivider />
        <MudListSubheader Class="mt-2 mb-n2">
            <MudIcon Icon="@Icons.Material.Outlined.Dashboard" Size="Size.Small" Class="mr-1" />@_localizer["Tableau de bord"]
        </MudListSubheader>
        <MudNavLink Href="/dashboard" Icon="@Icons.Material.Outlined.BarChart">
            @_localizer["Dashboard"]
        </MudNavLink>
    }

    @* ── CASH POWER ── *@
    @if (_canViewCashPower)
    {
        <MudDivider />
        <MudListSubheader Class="mt-2 mb-n2">
            <MudIcon Icon="@Icons.Material.Outlined.Bolt" Size="Size.Small" Class="mr-1" />@_localizer["Cash Power"]
        </MudListSubheader>
        <MudNavLink Href="/pos" Icon="@Icons.Material.Outlined.PointOfSale">
            @_localizer["Point de Vente"]
        </MudNavLink>
        <MudNavLink Href="/sales" Icon="@Icons.Material.Outlined.ShoppingBag">
            @_localizer["Historique Ventes"]
        </MudNavLink>
        @if (_canOpenShift)
        {
            <MudNavLink Href="/my-shift" Icon="@Icons.Material.Outlined.PointOfSale">
                @_localizer["Ma Caisse"]
            </MudNavLink>
        }
    }

    @* ── RECOUVREMENT ── *@
    @if (_canViewAllShifts)
    {
        <MudDivider />
        <MudListSubheader Class="mt-2 mb-n2">
            <MudIcon Icon="@Icons.Material.Outlined.AccountBalanceWallet" Size="Size.Small" Class="mr-1" />@_localizer["Recouvrement"]
        </MudListSubheader>
        <MudNavLink Href="/cash-shifts" Icon="@Icons.Material.Outlined.Receipt">
            @_localizer["Caisses"]
        </MudNavLink>
    }

    @* ── GESTION IMMOBILIÈRE ── *@
    @if (_canViewBuildings)
    {
        <MudDivider />
        <MudListSubheader Class="mt-2 mb-n2">
            <MudIcon Icon="@Icons.Material.Outlined.Apartment" Size="Size.Small" Class="mr-1" />@_localizer["Gestion Immobilière"]
        </MudListSubheader>
        <MudNavLink Href="/Buildings" Icon="@Icons.Material.Outlined.Business">
            @_localizer["Immeubles"]
        </MudNavLink>
        <MudNavLink Href="/Stores" Icon="@Icons.Material.Outlined.Storefront">
            @_localizer["Boutiques"]
        </MudNavLink>
        <MudNavLink Href="/Meters" Icon="@Icons.Material.Outlined.ElectricalServices">
            @_localizer["Compteurs"]
        </MudNavLink>
    }

    @* ── VENDEURS ── *@
    @if (_canViewSellers)
    {
        <MudDivider />
        <MudListSubheader Class="mt-2 mb-n2">
            <MudIcon Icon="@Icons.Material.Outlined.Badge" Size="Size.Small" Class="mr-1" />@_localizer["Vendeurs"]
        </MudListSubheader>
        <MudNavLink Href="/sellers" Icon="@Icons.Material.Outlined.PeopleAlt">
            @_localizer["Liste vendeurs"]
        </MudNavLink>
    }

    @* ── ADMINISTRATION ── *@
    @if (_canViewUsers || _canViewRoles)
    {
        <MudDivider />
        <MudListSubheader Class="mt-2 mb-n2">
            <MudIcon Icon="@Icons.Material.Outlined.AdminPanelSettings" Size="Size.Small" Class="mr-1" />@_localizer["Administration"]
        </MudListSubheader>
        @if (_canViewUsers)
        {
            <MudNavLink Href="/identity/users" Icon="@Icons.Material.Outlined.Person">
                @_localizer["Users"]
            </MudNavLink>
        }
        @if (_canViewRoles)
        {
            <MudNavLink Href="/identity/roles" Icon="@Icons.Material.Outlined.Security">
                @_localizer["Roles"]
            </MudNavLink>
        }
    }

    <MudNavLink Href="/account" Icon="@Icons.Material.Outlined.SupervisorAccount" Class="mt-2">
        @_localizer["Account"]
    </MudNavLink>

    <MudDivider Class="my-2" />
    <MudButton Variant="Variant.Text" Color="Color.Error" FullWidth="true"
               StartIcon="@Icons.Material.Filled.Logout" Class="justify-start pl-6"
               OnClick="LogoutAsync">
        @_localizer["Logout"]
    </MudButton>
</MudNavMenu>

@code {
    private ClaimsPrincipal _authenticationStateProviderUser;

    private bool _canViewDashboards;
    private bool _canViewRoles;
    private bool _canViewUsers;
    private bool _canViewCashPower;
    private bool _canViewBuildings;
    private bool _canViewSellers;
    private bool _canOpenShift;
    private bool _canViewAllShifts;

    protected override async Task OnParametersSetAsync()
    {
        _authenticationStateProviderUser = await _stateProvider.GetAuthenticationStateProviderUserAsync();
        _canViewDashboards = (await _authorizationService.AuthorizeAsync(_authenticationStateProviderUser, Permissions.Dashboards.View)).Succeeded;
        _canViewRoles = (await _authorizationService.AuthorizeAsync(_authenticationStateProviderUser, Permissions.Roles.View)).Succeeded;
        _canViewUsers = (await _authorizationService.AuthorizeAsync(_authenticationStateProviderUser, Permissions.Users.View)).Succeeded;
        _canViewCashPower = (await _authorizationService.AuthorizeAsync(_authenticationStateProviderUser, Permissions.CashPower.View)).Succeeded;
        _canViewBuildings = (await _authorizationService.AuthorizeAsync(_authenticationStateProviderUser, Permissions.BuildingParams.View)).Succeeded;
        _canViewSellers = (await _authorizationService.AuthorizeAsync(_authenticationStateProviderUser, Permissions.Sellers.View)).Succeeded;
        _canOpenShift = (await _authorizationService.AuthorizeAsync(_authenticationStateProviderUser, Permissions.CashShifts.Open)).Succeeded;
        _canViewAllShifts = (await _authorizationService.AuthorizeAsync(_authenticationStateProviderUser, Permissions.CashShifts.ViewAll)).Succeeded;
    }

    private async Task LogoutAsync()
    {
        await _authenticationManager.Logout();
        _navigationManager.NavigateTo("/login");
    }
}