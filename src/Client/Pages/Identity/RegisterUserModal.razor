@inject Microsoft.Extensions.Localization.IStringLocalizer<RegisterUserModal> _localizer
@using BlazorHero.CleanArchitecture.Shared.Constants.User

<EditForm Model="@_registerUserModel" OnValidSubmit="SubmitAsync">
    <FluentValidationValidator @ref="_fluentValidationValidator" />
    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-3 mb-n1" />
                Ajouter un utilisateur
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                Le mot de passe par dķfaut est <b>@UserConstants.DefaultPassword</b>. L'utilisateur devra le changer Ó la premiĶre connexion.
            </MudAlert>
            <MudTextField For="@(() => _registerUserModel.FirstName)" @bind-Value="_registerUserModel.FirstName" Label="Prķnom" Variant="Variant.Outlined" />
            <MudTextField For="@(() => _registerUserModel.LastName)" @bind-Value="_registerUserModel.LastName" Label="Nom" Variant="Variant.Outlined" Class="mt-3" />
            <MudTextField For="@(() => _registerUserModel.Email)" InputType="InputType.Email" @bind-Value="_registerUserModel.Email" Label="E-mail" Variant="Variant.Outlined" Class="mt-3" />
            <MudTextField For="@(() => _registerUserModel.PhoneNumber)" @bind-Value="_registerUserModel.PhoneNumber" Label="Tķlķphone" Variant="Variant.Outlined" Class="mt-3" />
        </DialogContent>
        <DialogActions>
            <MudButton Variant="Variant.Text" OnClick="Cancel">Annuler</MudButton>
            <MudButton Variant="Variant.Filled" ButtonType="ButtonType.Submit" Disabled="@(!Validated)" Color="Color.Primary">Crķer l'utilisateur</MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>