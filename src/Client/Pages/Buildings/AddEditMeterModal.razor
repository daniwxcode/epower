
<EditForm Model="@Model" OnValidSubmit="SaveAsync">
    <FluentValidationValidator @ref="_fluentValidationValidator" />
    <MudDialog>
        <TitleContent>
            @{
                if (Model.Id == 0)
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                        @_localizer["Ajouter"]
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Update" Class="mr-3 mb-n1" />
                        @_localizer["Modifier"]
                    </MudText>
                }
            }
        </TitleContent>
        <DialogContent>
            <MudGrid>
                @if (Model.Id != 0)
                {
                    <MudItem xs="12" md="6">
                        <MudTextField Disabled For="@(() => Model.Id)" @bind-Value="Model.Id" Label="@_localizer["Id"]" />
                        </MudItem>
                }
                <MudItem xs="12" md="6">
                    <MudTextField T="string" For="@(() => Model.Code)" @bind-Value="Model.Code" Label="@_localizer["Code"]" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField For="@(() => Model.SerialNumber)" @bind-Value="Model.SerialNumber" Label="@_localizer["Numéro Compteur"]" />
                </MudItem>                
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton DisableElevation Variant="Variant.Filled" OnClick="Cancel">@_localizer["Annuler"]</MudButton>
            @if (Model.Id != 0)
            {
                <MudButton DisableElevation Variant="Variant.Filled" ButtonType="ButtonType.Submit" Disabled="@(!Validated)" Color="Color.Secondary">@_localizer["Modifier"]</MudButton>
            }
            else
            {
                <MudButton DisableElevation Variant="Variant.Filled" ButtonType="ButtonType.Submit" Disabled="@(!Validated)" Color="Color.Success">@_localizer["Enregistrer"]</MudButton>
            }
        </DialogActions>
    </MudDialog>
</EditForm>