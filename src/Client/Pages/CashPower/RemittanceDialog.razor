@using BlazorHero.CleanArchitecture.Application.Features.Sellers.Commands
@using BlazorHero.CleanArchitecture.Client.Infrastructure.Managers.Sellers
@using System.Globalization

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-3">
            Vendeur : <b>@SellerName</b> — Montant attendu : <b>@ExpectedBalance.ToString("N0", _fr) FCFA</b>
        </MudText>
        <MudNumericField @bind-Value="_amount" Label="Montant remis (FCFA)"
                         Variant="Variant.Outlined" Min="0m" FullWidth="true" Required="true" />
        <MudTextField @bind-Value="_notes" Label="Notes (optionnel)"
                      Variant="Variant.Outlined" Lines="2" FullWidth="true" Class="mt-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAsync" Disabled="@(_amount <= 0)">
            Enregistrer la remise
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private static readonly CultureInfo _fr = CultureInfo.GetCultureInfo("fr-FR");

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }
    [Inject] private ICashShiftManager CashShiftManager { get; set; }
    [Inject] private ISnackbar Snackbar { get; set; }

    [Parameter] public int ShiftId { get; set; }
    [Parameter] public string SellerName { get; set; }
    [Parameter] public decimal ExpectedBalance { get; set; }

    private decimal _amount;
    private string _notes;

    private async Task SubmitAsync()
    {
        var result = await CashShiftManager.CreateRemittanceAsync(new CreateCashRemittanceCommand
        {
            CashShiftId = ShiftId,
            Amount = _amount,
            Notes = _notes
        });

        if (result.Succeeded)
        {
            Snackbar.Add(result.Messages[0], MudBlazor.Severity.Success);
            MudDialog.Close(DialogResult.Ok(result.Data));
        }
        else
        {
            foreach (var msg in result.Messages)
            {
                Snackbar.Add(msg, MudBlazor.Severity.Error);
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
