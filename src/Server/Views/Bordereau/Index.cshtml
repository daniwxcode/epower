@model BuyCreditResponse
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <style>
        body {
            font-family: Arial;
            padding: 2cm;
        }

        .logo {
            width: 200px;
        }

        .standard-text {
            font-size: 0.9em;
        }

        .qrcode {
            float: right;
            width: 100px;
        }

        .numero-requisition {
            font-size: 3em;
            text-align: center;
            border: 1px black solid;
        }

        .title {
            font-size: 24px;
            text-align: center;
        }

        .subtitle {
            font-size: 20px;
            text-align: center;
        }

        hr {
            width: 100%;
            color: #10487c
        }

        #watermark {
            color: #d0d0d0;
            font-size: 100pt;
            -webkit-transform: rotate(-65deg);
            -moz-transform: rotate(-65deg);
            position: absolute;
            width: 100%;
            height: 100%;
            margin: 0;
            z-index: -1;
            left: -50px;
            top: 1000px;
        }
    </style>
</head>
<body style="background-image: url('media/voltmeter.png');
background-repeat:repeat; background-size: 192.9px 106.1px;background-color: rgba(255,255,255,0.9);background-blend-mode: lighten;">
    <div style="margin-left: auto; margin-right: auto">
        <br />
        <br /><br />
        <br />
        <h2 style="text-align:center">REÇU DE VENTE</h2>
        <hr />
        <h4>
            <i>COMPTEUR</i>
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;

            <b>@Model.SerialNumber</b>
        </h4>
        <p>
            @Model.Message()
        </p>
        <h4><i>D&Eacute;TAIL</i></h4>
        <hr />
        <table class='standard-text' style="width: 100%; margin-right: auto; margin-left: auto;">
            <tr>
                <td style="width:30%;">REFERENCE:</td>
                <td>@Model.Reference</td>
            </tr>
            <tr>
                <td style="width:30%;">MONTANT:</td>
                <td>@Model.Amount</td>
            </tr> <tr>
                <td style="width:30%;">FRAIS:</td>
                <td>@((int)Model.fees)</td>
            </tr>
            <tr>
                <td style="width:30%;">MONTANT:</td>
                <td>@Model.Amount</td>
            </tr>
            <tr>
                <td style="width:30%;">TOTAL:</td>
                <td>@(Model.fees + (int)Model.Amount)</td>
            </tr>
            <tr>
                <td style="width:30%;">CODE :</td>
                <td>@Model.Code</td>
            </tr>
            <tr>
                <td style="width:30%;">Quantité:</td>
                <td>@Model.Credit KW</td>
            </tr>
            <tr>
                <td style="width:30%;">DATE</td>
                <td>@Model.date.ToShortDateString()</td>
            </tr>

        </table>
        <hr />
        <table class='standard-text' style="width: 100%; margin-right: auto; margin-left: auto;">
            <tr>
                <td class="logo" style='width:70%;'>
                    <img src="@ViewData["QrCode"]" />
                </td>
                <td style="text-align: center; ">
                    VENDEUR:<br/> @Model.Seller
                </td>
            </tr>
        </table>
    </div>
</body>

</html>